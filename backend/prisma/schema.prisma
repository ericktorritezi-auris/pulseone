generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================
// ENUMS
// ==========================

enum UserRole {
  ADMIN
  GESTOR
  COLABORADOR
}

enum PulseCycleStatus {
  RASCUNHO
  ABERTO
  ENCERRADO
  EM_CONSOLIDACAO
  FINALIZADO
  ARQUIVADO
}

enum PulseEvaluationType {
  AUTOAVALIACAO
  AVALIACAO_EQUIPE // gestor avalia um liderado direto (descendente)
  AVALIACAO_GESTOR // qualquer pessoa avalia o próprio gestor direto (ascendente)
  COLEGA
}

enum PulseEvaluationStatus {
  PENDENTE
  FINALIZADO
}

enum PulseReportStatus {
  EM_ANDAMENTO
  AGUARDANDO_FECHAMENTO
  FINALIZADO
  ARQUIVADO
}

enum AuditAction {
  LOGIN
  LOGOUT
  CADASTRO
  EDICAO
  EXCLUSAO
  FEEDBACK
  FECHAMENTO
  GERACAO_IA
  GERACAO_PDF
}

// ==========================
// ENTIDADES PRINCIPAIS
// ==========================

model User {
  id            String     @id @default(uuid())
  fullName      String
  email         String
  emailVerified Boolean    @default(false)
  phone         String
  passwordHash  String
  mustChangePwd Boolean    @default(false)
  role          UserRole
  // Opcionais: só o ADMIN não pertence a nenhuma área/cargo (é uma entidade
  // do sistema, não um colaborador da organização). Todo GESTOR/COLABORADOR
  // continua exigindo os dois — a validação fica na camada de aplicação
  // (UsersService), já que o Prisma não faz "obrigatório condicional".
  areaId        String?
  area          Area?      @relation(fields: [areaId], references: [id])
  positionId    String?
  position      Position?  @relation(fields: [positionId], references: [id])
  // Gestor direto explícito (hierarquia dentro da área): quem avalia esta
  // pessoa no tipo GESTOR, e com quem ela forma "mesmo time imediato" pra
  // fins de avaliação de colegas. Opcional — null = topo da hierarquia
  // (ninguém acima dentro do sistema).
  managerId     String?
  manager       User?      @relation("DirectReports", fields: [managerId], references: [id])
  directReports User[]     @relation("DirectReports")
  // Áreas de atuação ADICIONAIS de um gestor (além da área principal em
  // `areaId`) — pedido do Erick: um gestor pode gerenciar mais de uma área
  // ao mesmo tempo. Isso só afeta QUEM PODE SER ESCOLHIDO como Gestor
  // Direto de alguém — nunca afeta avaliação de colegas, que continua
  // restrita à mesma área (seção 5.7 + correção da seção 5.25).
  managedAreas  Area[]     @relation("GestorAreas")
  active        Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  feedbacksSent           Feedback[]              @relation("FeedbackSender")
  feedbacksReceived       Feedback[]              @relation("FeedbackReceiver")
  pulseFeedbacksGiven     PulseFeedback[]         @relation("PulseEvaluator")
  pulseFeedbacksReceived  PulseFeedback[]         @relation("PulseTarget")
  pulseScores             PulseScore[]
  pulseReports            PulseReport[]           @relation("ReportOwner")
  notifications           Notification[]
  auditLogs               AuditLog[]
  systemNpsParticipations SystemNpsParticipation[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]

  // Sem @unique de propósito (seção 5.17): a mesma pessoa pode ter mais de
  // uma conta com o mesmo e-mail (ex: admin e gestor sendo a mesma pessoa).
  // O índice é só pra performance nas buscas por e-mail (login etc.).
  @@index([email])
}

model Area {
  id        String   @id @default(uuid())
  name      String   @unique
  users     User[]
  positions Position[]
  gestoresAtuantes User[] @relation("GestorAreas")
  createdAt DateTime @default(now())
}

model Position {
  id        String   @id @default(uuid())
  name      String
  isManager Boolean  @default(false)
  areaId    String
  area      Area     @relation(fields: [areaId], references: [id])
  users     User[]
  createdAt DateTime @default(now())

  // Nome único DENTRO da área, não mais globalmente — agora que cargo
  // pertence a uma área, "Analista" pode existir em Marketing E em Vendas
  // como cargos distintos, sem precisar escrever "Analista de X" toda vez.
  @@unique([name, areaId])
}

// ==========================
// TOKENS DE AUTENTICAÇÃO
// ==========================

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// ==========================
// FEEDBACK CONTÍNUO
// ==========================

model Feedback {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("FeedbackSender", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("FeedbackReceiver", fields: [receiverId], references: [id])
  text       String
  npsScore   Int
  createdAt  DateTime @default(now())
}

// ==========================
// FEEDBACK PULSE (CICLO 360°)
// ==========================

model PulseCycle {
  id         String           @id @default(uuid())
  label      String
  status     PulseCycleStatus @default(RASCUNHO)
  openedAt   DateTime?
  deadline   DateTime?
  closedAt   DateTime?
  archivedAt DateTime?
  createdAt  DateTime         @default(now())

  pulseFeedbacks PulseFeedback[]
  pulseScores    PulseScore[]
  pulseReports   PulseReport[]
}

model PulseQuestion {
  id        String        @id @default(uuid())
  order     Int
  text      String
  dimension String
  isNps     Boolean       @default(false)
  active    Boolean       @default(true)
  answers   PulseAnswer[]
}

model PulseFeedback {
  id          String                @id @default(uuid())
  cycleId     String
  cycle       PulseCycle            @relation(fields: [cycleId], references: [id])
  evaluatorId String
  evaluator   User                  @relation("PulseEvaluator", fields: [evaluatorId], references: [id])
  targetId    String
  target      User                  @relation("PulseTarget", fields: [targetId], references: [id])
  type        PulseEvaluationType
  status      PulseEvaluationStatus @default(PENDENTE)
  comment     String?
  finishedAt  DateTime?
  createdAt   DateTime              @default(now())

  answers PulseAnswer[]

  @@unique([cycleId, evaluatorId, targetId, type])
}

model PulseAnswer {
  id              String        @id @default(uuid())
  pulseFeedbackId String
  pulseFeedback   PulseFeedback @relation(fields: [pulseFeedbackId], references: [id])
  questionId      String
  question        PulseQuestion @relation(fields: [questionId], references: [id])
  value           Int

  @@unique([pulseFeedbackId, questionId])
}

model PulseScore {
  id           String     @id @default(uuid())
  cycleId      String
  cycle        PulseCycle @relation(fields: [cycleId], references: [id])
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  teamScore    Float
  managerScore Float
  selfScore    Float
  finalScore   Float
  npsScore     Float
  scoreBand    String
  createdAt    DateTime   @default(now())

  @@unique([cycleId, userId])
}

// ==========================
// PARECER, IA E RELATÓRIO
// ==========================

model PulseReport {
  id                  String            @id @default(uuid())
  cycleId             String
  cycle               PulseCycle        @relation(fields: [cycleId], references: [id])
  ownerId             String
  owner               User              @relation("ReportOwner", fields: [ownerId], references: [id])
  status              PulseReportStatus @default(EM_ANDAMENTO)
  managerFinalOpinion String?
  finalizedById       String?
  finalizedAt         DateTime?
  pdfUrl              String?
  createdAt           DateTime          @default(now())

  aiAnalysis PulseAiAnalysis?
}

model PulseAiAnalysis {
  id               String      @id @default(uuid())
  reportId         String      @unique
  report           PulseReport @relation(fields: [reportId], references: [id])
  strengths        String
  improvements     String
  trends           String
  summary          String
  suggestedOpinion String
  model            String
  regenCount       Int         @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

// ==========================
// NOTIFICAÇÕES E AUDITORIA
// ==========================

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String      @id @default(uuid())
  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
  action    AuditAction
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime    @default(now())
}

// ==========================
// NPS DO SISTEMA (não confundir com o NPS de pessoas, dentro do Pulse)
// ==========================

// Cada "disparo" de pesquisa pelo admin. Não guarda quem disparou por
// simplicidade — só importa QUANDO, pra saber qual é "a mais recente".
model SystemNpsCampaign {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  participations SystemNpsParticipation[]
  responses      SystemNpsResponse[]
}

// Só registra QUE a pessoa já respondeu a campanha X — nunca o que ela
// respondeu. Existe só pra decidir "mostro o modal de novo ou não" no
// próximo login. "Agora não" nunca gera uma linha aqui (pedido do Erick:
// só Enviar "resolve" a pessoa pra aquela campanha).
model SystemNpsParticipation {
  id          String            @id @default(uuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  campaignId  String
  campaign    SystemNpsCampaign @relation(fields: [campaignId], references: [id])
  respondedAt DateTime          @default(now())

  @@unique([userId, campaignId])
}

// A resposta em si — DE PROPÓSITO sem nenhum campo de usuário. Ninguém,
// nem admin, nem com acesso direto ao banco, consegue ligar uma resposta
// a uma pessoa específica. campaignId é só contexto de quando foi
// coletada, não identifica ninguém.
model SystemNpsResponse {
  id         String             @id @default(uuid())
  score      Int
  comment    String?
  campaignId String?
  campaign   SystemNpsCampaign? @relation(fields: [campaignId], references: [id])
  createdAt  DateTime           @default(now())
}
